# Adyapan School App — Environment Variables
# This file is bundled as a Flutter asset

# Backend API URL (deployed on Render — shared across all 3 projects)
API_BASE_URL=https://preschool-wzjj.onrender.com

# Direct TiDB connection (used by DbHelper for real-time data sync)
# These are only needed if you want direct DB access from the mobile app
# MYSQL_HOST=
# MYSQL_PORT=4000
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=preschool
# MYSQL_SSL=true
