# ─── Database (TiDB Cloud / MySQL) ───────────────────────────────────
# IMPORTANT: This MUST point to the same database as all other Adyapan projects
DATABASE_URL="mysql://username:password@your-tidb-host.tidbcloud.com:4000/preschool"

# Raw MySQL
MYSQL_HOST=your-tidb-host.tidbcloud.com
MYSQL_PORT=4000
MYSQL_USER=username
MYSQL_PASSWORD=password
MYSQL_DATABASE=preschool
MYSQL_SSL=true

# ─── JWT ─────────────────────────────────────────────────────────────
# IMPORTANT: JWT_SECRET must be the SAME across all 3 projects (Preschool, adyapanschool, adyapan_admin)
# so that tokens issued by one backend are valid on the others.
JWT_SECRET=your-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ─────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS (comma-separated origins for production) ───────────────────
# Leave empty for dev (allows all). Set for production:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
CORS_ORIGINS=

# ─── API Base URL (for Flutter mobile app to call this backend) ──────
# Set this to your deployed backend URL when in production
# API_BASE_URL=https://adyapanschool-backend.onrender.com

# ─── AWS S3 File Storage (for video uploads) ─────────────────────────
# Create a free AWS account at https://aws.amazon.com
# Then create an S3 bucket and get credentials from IAM
# If these are not set, uploaded files will be stored locally (not recommended for production)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# ─── AWS RDS MySQL (Secondary / Backup Database) ─────────────────────
# Free Tier: db.t3.micro, 20 GB — 12 months free on AWS
# After creating RDS instance, run:
#   npm run rds:schema    (creates tables on RDS from prisma schema)
#   npm run rds:migrate   (copies all TiDB data to RDS)
# After that all writes auto-mirror to RDS (dual-write enabled).
AWS_RDS_HOST=your-db-instance.rds.amazonaws.com
AWS_RDS_PORT=3306
AWS_RDS_USER=admin
AWS_RDS_PASSWORD=your-rds-password
AWS_RDS_DATABASE=preschool
AWS_RDS_SSL=true
