{
  "name": "adyapan-unified-backend",
  "version": "1.0.0",
  "description": "Unified Adyapan Backend - Express + Prisma + TiDB",
  "main": "server.js",
  "scripts": {
    "build": "npx prisma generate",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "npx prisma generate",
